ANTHROPIC_API_KEY=sk-ant-...
HELIUS_API_KEY=your-helius-api-key
WALLET_ADDRESS=your-solana-wallet-address

REBALANCE_THRESHOLD_PCT=5     # rebalance when drift exceeds 5%
MIN_TRADE_USD=50               # ignore drifts below $50
DRY_RUN=true                   # set false to execute live trades
CHECK_INTERVAL_MS=3600000      # check every hour
CLAUDE_MODEL=claude-sonnet-4-6
